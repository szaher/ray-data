{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tutorial-spec.schema.json",
  "title": "TutorialSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "audience",
    "prerequisites",
    "learningObjectives",
    "scope",
    "lessons",
    "references",
    "concepts",
    "misconceptions",
    "workedExamples",
    "exercises",
    "answers",
    "formativeAssessment",
    "masteryCriteria",
    "recap",
    "nextSteps",
    "accessibility",
    "localization"
  ],
  "properties": {
    "schemaVersion": { "enum": ["1.0.0", "1.1.0"] },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "audience": {
      "type": "object",
      "required": ["primary", "priorKnowledge"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "priorKnowledge": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "roles": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "readingLevel": { "type": "string" }
      }
    },
    "prerequisites": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "learningObjectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "bloomLevel", "assessmentIds"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "bloomLevel": { "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"] },
          "assessmentIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "scope": {
      "type": "object",
      "required": ["inScope", "nonGoals"],
      "properties": {
        "inScope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "nonGoals": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "slug", "title", "summary", "estimatedMinutes", "difficulty", "prerequisites", "objectiveIds", "conceptIds", "referenceIds", "artifacts"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "estimatedMinutes": { "type": "number", "minimum": 1 },
          "difficulty": { "enum": ["beginner", "intermediate", "advanced"] },
          "prerequisites": { "type": "array", "items": { "type": "string" } },
          "objectiveIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "conceptIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "referenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "dependsOnLessonIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "multimediaPlan": { "$ref": "#/$defs/multimediaPlan" },
          "metacognition": {
            "type": "array",
            "items": { "$ref": "#/$defs/metacognitionStrategy" }
          },
          "scaffolding": { "$ref": "#/$defs/scaffoldingConfig" },
          "artifacts": {
            "type": "object",
            "required": ["mdxPath"],
            "properties": {
              "mdxPath": { "type": "string", "minLength": 1 },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifactDescriptor" }
              },
              "slidesPath": { "type": "string" },
              "narrationScriptPath": { "type": "string" },
              "infographicPath": { "type": "string" }
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "accessedAt", "quality"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "publisher": { "type": "string" },
          "accessedAt": { "type": "string" },
          "quality": { "enum": ["primary", "official-docs", "peer-reviewed", "expert", "secondary", "unverified"] },
          "notes": { "type": "string" }
        }
      }
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "term", "definition"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "term": { "type": "string", "minLength": 1 },
          "definition": { "type": "string", "minLength": 1 },
          "relatedConceptIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "misconceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "misconception", "correction", "conceptIds"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "misconception": { "type": "string", "minLength": 1 },
          "correction": { "type": "string", "minLength": 1 },
          "conceptIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "workedExamples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "prompt", "steps", "explanation", "conceptIds"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "steps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "explanation": { "type": "string", "minLength": 1 },
          "conceptIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "referenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "exercises": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "prompt", "type", "difficulty", "conceptIds", "answerId"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "type": { "enum": ["short-answer", "multiple-choice", "coding", "reflection", "scenario"] },
          "difficulty": { "enum": ["beginner", "intermediate", "advanced"] },
          "conceptIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "answerId": { "type": "string", "minLength": 1 }
        }
      }
    },
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "exerciseId", "answer"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "exerciseId": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 },
          "rubric": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "formativeAssessment": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "prompt", "objectiveIds"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "enum": ["quiz", "free-response", "performance-task", "self-check"] },
          "prompt": { "type": "string", "minLength": 1 },
          "expectedAnswer": { "type": "string" },
          "objectiveIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "masteryCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "objectiveIds", "threshold"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "objectiveIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "threshold": { "type": "string", "minLength": 1 }
        }
      }
    },
    "recap": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "nextSteps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "accessibility": {
      "type": "object",
      "properties": {
        "altTextRequired": { "type": "boolean" },
        "captionsRequired": { "type": "boolean" },
        "transcriptRequired": { "type": "boolean" },
        "colorIndependent": { "type": "boolean" },
        "keyboardNavigable": { "type": "boolean" },
        "readingOrderChecked": { "type": "boolean" }
      }
    },
    "localization": {
      "type": "object",
      "properties": {
        "sourceLocale": { "type": "string" },
        "targetLocales": { "type": "array", "items": { "type": "string" } },
        "glossaryTerms": { "type": "array", "items": { "type": "string" } },
        "culturalAssumptions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "contentStyle": {
      "type": "object",
      "properties": {
        "voice": { "enum": ["conversational", "academic", "systematic", "narrative", "minimalist"] },
        "approaches": {
          "type": "array",
          "items": { "enum": ["socratic", "problem-based", "hands-on", "analogical", "visual-first", "challenge-based"] }
        },
        "generationMode": { "enum": ["sequential", "parallel"] }
      }
    },
    "gamification": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "badges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "description", "criteria", "iconHint"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "criteria": { "type": "string", "minLength": 1 },
              "iconHint": { "type": "string", "minLength": 1 }
            }
          }
        },
        "pointRules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action", "points", "description"],
            "properties": {
              "action": { "type": "string", "minLength": 1 },
              "points": { "type": "number" },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "streakTracking": { "type": "boolean" },
        "achievements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "description"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "unlocksLessonIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            }
          }
        },
        "unlockableContent": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "adaptivePaths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "entryCondition", "lessonSequence", "difficulty"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "entryCondition": { "type": "string", "minLength": 1 },
          "lessonSequence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "difficulty": { "enum": ["beginner", "intermediate", "advanced"] }
        }
      }
    },
    "spacedRepetition": {
      "type": "object",
      "required": ["enabled", "intervals", "reviewCardCount"],
      "properties": {
        "enabled": { "type": "boolean" },
        "intervals": { "type": "array", "items": { "type": "number" } },
        "reviewCardCount": { "type": "number", "minimum": 1 }
      }
    },
    "microlearning": {
      "type": "object",
      "required": ["enabled", "maxMinutesPerModule", "digestFormat"],
      "properties": {
        "enabled": { "type": "boolean" },
        "maxMinutesPerModule": { "type": "number", "minimum": 1 },
        "digestFormat": { "enum": ["flashcard", "summary", "quiz"] }
      }
    },
    "projectCapstones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "deliverables", "rubric", "estimatedHours", "prerequisiteLessonIds", "conceptIds"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "deliverables": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "rubric": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "estimatedHours": { "type": "number", "minimum": 0 },
          "prerequisiteLessonIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "conceptIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "udlFramework": {
      "type": "object",
      "required": ["multipleRepresentations", "multipleActions", "multipleEngagement"],
      "properties": {
        "multipleRepresentations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "multipleActions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "multipleEngagement": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "collaborativeLearning": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "groupSize": { "type": "number", "minimum": 2 },
        "activities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "peerReviewEnabled": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "multimediaPlan": {
      "type": "object",
      "required": ["recommendations"],
      "properties": {
        "recommendations": {
          "type": "array",
          "items": { "$ref": "#/$defs/multimediaRecommendation" }
        }
      }
    },
    "multimediaRecommendation": {
      "type": "object",
      "required": ["id", "type", "rationale", "priority", "placement", "contentBrief", "accessibilityNotes", "estimatedEffort"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["slides", "narration", "mermaid", "mind-map", "infographic", "timeline", "comparison-matrix", "decision-tree", "concept-map", "interactive-simulation"] },
        "rationale": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["required", "recommended", "optional"] },
        "placement": { "type": "string", "minLength": 1 },
        "contentBrief": { "type": "string", "minLength": 1 },
        "accessibilityNotes": { "type": "string", "minLength": 1 },
        "objectiveIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "mermaidSource": { "type": "string" },
        "estimatedEffort": { "enum": ["low", "medium", "high"] }
      }
    },
    "metacognitionStrategy": {
      "type": "object",
      "required": ["type", "prompt", "placement"],
      "properties": {
        "type": { "enum": ["self-assessment", "reflection", "goal-setting", "knowledge-monitoring"] },
        "prompt": { "type": "string", "minLength": 1 },
        "placement": { "enum": ["before-lesson", "mid-lesson", "after-lesson"] }
      }
    },
    "scaffoldingConfig": {
      "type": "object",
      "required": ["hintLevels", "differentiatedPaths", "graduatedComplexity"],
      "properties": {
        "hintLevels": { "type": "number", "minimum": 1 },
        "differentiatedPaths": { "type": "boolean" },
        "graduatedComplexity": { "type": "boolean" }
      }
    },
    "artifactDescriptor": {
      "type": "object",
      "required": ["id", "type", "status", "objectiveIds", "accessibility"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["slides", "narration", "mermaid", "mind-map", "infographic", "timeline", "comparison-matrix", "decision-tree", "concept-map", "interactive-simulation"] },
        "status": { "enum": ["planned", "generated", "approved"] },
        "sourcePath": { "type": "string" },
        "renderedPath": { "type": "string" },
        "objectiveIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "accessibility": {
          "type": "object",
          "required": ["fallbackText"],
          "properties": {
            "altText": { "type": "string" },
            "transcriptPath": { "type": "string" },
            "captionsPath": { "type": "string" },
            "fallbackText": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
